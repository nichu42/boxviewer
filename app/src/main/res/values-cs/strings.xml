    <string name="aqi_info_title">"Průvodce indexem kvality ovzduší"</string>
    <string name="aqi_info_intro_title">"Pochopení indexu kvality ovzduší (AQI)"</string>
    <string name="aqi_info_intro_description">"Index kvality ovzduší je standardizovaný systém používaný k hlášení denní kvality ovzduší a jejímu propojení s riziky pro veřejné zdraví. BoxViewer vytvoří lokální 'virtuální' AQI senzor, když stanice publikuje hodnoty prachu PM2.5 nebo PM10."</string>
