    <!-- AQI info screen -->
    <string name="aqi_info_title">"Przewodnik po indeksie jakości powietrza"</string>
    <string name="aqi_info_intro_title">"Zrozumienie indeksu jakości powietrza (AQI)"</string>
    <string name="aqi_info_intro_description">"Indeks jakości powietrza to standaryzowany system służący do informowania o codziennej jakości powietrza i powiązania jej z zagrożeniami dla zdrowia publicznego. BoxViewer tworzy lokalny 'wirtualny' czujnik AQI, gdy stacja publikuje wartości pyłu zawieszonego PM2.5 lub PM10."</string>
    <string name="aqi_info_cast_title">"InstantCast a NowCast"</string>
    <string name="aqi_info_instantcast_title">"InstantCast (dane na żywo)"</string>
    <string name="aqi_info_instantcast_description">"Przetwarza najnowszy pojedynczy pomiar bezpośrednio przy użyciu standardowych wartości granicznych. Używany na głównym pulpicie i w widżetach w celu uzyskania czasu reakcji w czasie rzeczywistym."</string>
    <string name="aqi_info_nowcast_title">"NowCast (analiza historyczna)"</string>
    <string name="aqi_info_nowcast_description">"Wykorzystuje 12-godzinny algorytm średniej ważonej EPA. Jeśli jakość powietrza gwałtownie się zmienia, większą wagę przywiązuje się do ostatnich godzin; jeśli jest stabilna, wagi są bardziej równomierne. Obliczany i wyświetlany po rozwinięciu szczegółowych kart czujników."</string>
    <string name="aqi_info_virtual_sensor_title">"Skonsolidowany czujnik wirtualny"</string>
    <string name="aqi_info_virtual_sensor_description">"Jeśli stacja zawiera zarówno PM2.5 (pył zawieszony drobny), jak i PM10 (pył zawieszony gruby), BoxViewer oblicza cząstkowy indeks dla obu i automatycznie wyświetla najgorszą wartość (maksimum). Zapewnia to maksymalną ochronę i przejrzysty układ."</string>
