<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <!-- Header info -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/widget_box_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_default_box_name"
            android:textColor="#F8FAFC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="2dp"
            android:text="@string/widget_updated_just_now"
            android:textColor="#94A3B8"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="4dp"
            android:padding="3dp"
            android:src="@drawable/ic_refresh"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/widget_refresh"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/widget_settings_button"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="4dp"
            android:padding="3dp"
            android:src="@drawable/ic_gear"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/widget_configure"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Highly prominent single sensor display with modern visual plate background -->
    <LinearLayout
        android:id="@+id/widget_values_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_header"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/widget_inner_card_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/big_sensor_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_sensor_temp"
            android:contentDescription="@string/widget_sensor_category_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/big_sensor_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_no_value"
                android:textColor="#38BDF8"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/big_sensor_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_select_sensor"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:layout_marginTop="2.5dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
