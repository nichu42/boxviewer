    <!-- AQI info screen -->
    <string name="aqi_info_title">Air Quality Index Guide</string>
    <string name="aqi_info_intro_title">Understanding Air Quality Index (AQI)</string>
    <string name="aqi_info_intro_description">The Air Quality Index is a standardized system used to report daily air quality and associate it with public health risks. BoxViewer synthesizes a local \'virtual\' AQI sensor if a station publishes PM2.5 or PM10 particulate matter readings.</string>
    <string name="aqi_info_cast_title">InstantCast vs. NowCast</string>
    <string name="aqi_info_instantcast_title">InstantCast (Live Readings)</string>
    <string name="aqi_info_instantcast_description">Directly translates the most recent single measurement value using standard breakpoints. Used on the main dashboard list and widgets for real-time responsiveness.</string>
    <string name="aqi_info_nowcast_title">NowCast (Historical Analysis)</string>
    <string name="aqi_info_nowcast_description">Uses the EPA\'s 12-hour weighted average algorithm. If air quality is changing rapidly, it puts more weight on recent hours; if stable, it weights them more evenly. Calculated and displayed when expanding detailed sensor cards.</string>
    <string name="aqi_info_virtual_sensor_title">Consolidated Virtual Sensor</string>
    <string name="aqi_info_virtual_sensor_description">If a station contains both PM2.5 (fine particles) and PM10 (coarse particles), BoxViewer calculates the sub-index for both and automatically displays the worst-case (maximum) score. This ensures maximum protection and a clean layout.</string>
